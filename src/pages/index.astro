---
import "../styles/global.css";
// import CurrentWeatherCard from "../components/CurrentWeatherCard.astro";
import CurrentWeather from "../components/CurrentWeather.astro";

// import TopBar from "../components/TopBar.astro";
import FavCitiesDropdown from "../components/FavCitiesDropdown.astro";
import SearchBar from "../components/SearchBar.astro";

// Import team components
import DayCard from "../components/DayCard.astro";
import HoursCard from "../components/HoursCard.astro";

import SunRiseSet from "../components/SunRiseSet.astro";
import WeatherDetails from "../components/WeatherDetails.astro";

import { getWeatherInfo } from "../lib/weather";

// Default city: Vancouver, Canada
const DEFAULT_CITY = {
  name: "Vancouver",
  latitude: 49.2827,
  longitude: -123.1207,
};

let weatherInfo = undefined;
try {
  weatherInfo = await getWeatherInfo(
    DEFAULT_CITY.longitude,
    DEFAULT_CITY.latitude,
  );
} catch (e) {
  weatherInfo = undefined;
}

const placeholderDaily = Array.from({ length: 5 }).map((_, i) => ({
  date: "",
  maxTemp: 0,
  minTemp: 0,
  weatherCode: 0,
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>StrCats Weather</title>
  </head>
  <body class="bg-cover bg-center bg-no-repeat bg-fixed" style="background-image: url('/assets/bg-byTime/Day.svg');">
    <!-- > Loading screen -->
    <div
      id="global-loading-screen"
      class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-slate-900/90 text-white transition-opacity duration-500 ease-in-out"
    >
      <div class="flex flex-col items-center gap-4">
        <!-- Spinner -->
        <div
          class="w-12 h-12 border-4 border-t-blue-400 border-r-transparent border-b-blue-400 border-l-transparent rounded-full animate-spin"
        >
        </div>
        <p class="text-lg font-medium font-roboto tracking-wide animate-pulse">
          Loading Weather...
        </p>
      </div>
    </div>

    <main id="desktop-layout" class="hidden md:grid grid-cols-3 gap-4 min-h-screen pt-8 px-15 bg-cover bg-center bg-no-repeat bg-fixed">
      <!-- `Col 1` -->
      <header class="flex flex-col flex-1 h-full">
        <CurrentWeather />
      </header>
      <!-- `Col 2`  -->
      <section class="flex flex-col gap-6 flex-1 h-full">
        <!--  > Favourite Cities Dropdown -->
        <FavCitiesDropdown />
        <!-- > 5 Day Forecast -->
        <div class="max-w-150 w-full bg-white rounded-3xl p-5 shadow-inner shadow-black/50">
          <h3 class="text-xl lg:text-2xl font-bold text-gray-700 tracking-tight mb-4 ml-2">5 Day Forecast</h3>
          <div id="daily-forecast-container" class="flex flex-col gap-2 font-roboto md:flex-row items-stretch w-full overflow-hidden border-none divide-none">
            {placeholderDaily.map((forecast) => <DayCard forecast={forecast} />)}
          </div>
        </div>
        <!-- > Sunrise Sunset -->
        <SunRiseSet />
        <!-- > Weather Details -->
        <WeatherDetails />
      </section>
      <!-- `Col 3` -->
      <section class="h-[90%] flex flex-col">
        <!-- > Searchbar -->
        <SearchBar />
        <div id="hourly-range-container" class="flex-1 flex flex-col h-full">
          <HoursCard />
        </div>
      </section>
    </main>

    <main id="mobile-layout" class=" md:hidden min-h-screen p-4 flex flex-col gap-4">
      <!-- ` Search & Fav` -->
      <div class="top-0 z-40 p-2 flex items-center gap-2">
        <FavCitiesDropdown /> 
        <SearchBar />
      </div>

      <!-- > Current Weather -->
      <CurrentWeather />
      
      <!-- > 5 Days forecast -->
      <div class="bg-white rounded-3xl p-4 shadow-md">
        <h3 class="text-lg font-bold text-gray-700 mb-2">5-Day Forecast</h3>
        <div class="flex flex-row overflow-x-auto gap-2">
          {placeholderDaily.map((forecast) => <DayCard forecast={forecast} />)}
        </div>
      </div>

      <HoursCard />
      <SunRiseSet />
      <WeatherDetails />
    </main>
    
  </body>

  <script>
    import { initWeatherApp } from "../lib/init-weather-app";

    initWeatherApp();
  </script>
</html>
