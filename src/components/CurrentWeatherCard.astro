---
---

<section
  class="relative rounded-3xl bg-violet-800 to-slate-900 shadow-xl shadow-violet-900/30"
>
  <div class="relative grid gap-6 p-6 sm:grid-cols-[1fr_auto] sm:items-end sm:p-8 lg:p-10">
    <div class="min-w-0 space-y-4">
      <div class="flex flex-wrap items-start gap-3">
        <div>
          <h2 id="current-city-heading" class="text-3xl font-bold text-white sm:text-4xl">
            <span id="hero-city-name">Vancouver</span>
          </h2>
        </div>

        <!-- Favorite Toggle Button -->
        <button
          type="button"
          id="favorite-toggle"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/25 bg-white/10 text-amber-200 backdrop-blur-sm transition hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-300"
        >
          <img
            id="favorite-star-icon"
            src="/assets/icon-star.svg"
            alt=""
            width="24"
            height="24"
            class="pointer-events-none h-6 w-6 object-contain"
          />
        </button>
      </div>

      <div
        class="grid max-w-md grid-cols-2 gap-3 rounded-2xl border border-white/20 bg-white/15 p-4 text-white backdrop-blur-md"
      >
        <div>
          <p class="text-xs font-medium uppercase tracking-wide text-violet-100/80">Rain</p>
          <p id="hero-rain-value" class="mt-1 text-lg font-semibold">—</p>
        </div>
        <div>
          <p class="text-xs font-medium uppercase tracking-wide text-violet-100/80">Snowfall</p>
          <p id="hero-snow-value" class="mt-1 text-lg font-semibold">—</p>
        </div>
      </div>
    </div>

    <!-- Today Card -->
    <div
      class="w-full max-w-96 shrink-0 rounded-2xl bg-violet-600/90 p-5 text-white shadow-lg shadow-black/20 sm:justify-self-end"
    >
      <p class="mb-3 inline-block rounded-full bg-violet-950/30 px-2.5 py-0.5 text-xs font-medium">Today</p>
      <p id="hero-temp-main" class="text-center text-4xl font-bold tracking-tight">—</p>
      <p id="hero-temp-range" class="mt-2 text-center text-sm text-violet-100">—</p>
    </div>
  </div>

  <p
    id="hero-status"
    class="relative border-t border-white/10 bg-black/20 px-6 py-2 text-center text-xs text-violet-100 sm:px-8"
  >
    Loading forecast…
  </p>
</section>
