---
// src/components/HoursCard.astro
// This template defines the structure and layout for each hourly item.
---

<div class="hour-item" style="display: inline-block; text-align: center; padding: 15px; min-width: 80px;">
  <div class="hour-time" style="font-size: 0.9rem; color: #555;">-- AM</div>
  <div class="hour-emoji" style="font-size: 1.5rem; margin: 5px 0;">❓</div>
  <div class="hour-temp" style="font-weight: bold;">--°</div>
</div>