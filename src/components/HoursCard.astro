---
// src/components/HoursCard.astro
---

<div class="bg-white/90 backdrop-blur-md border border-gray-200/60 rounded-[32px] p-5 shadow-sm max-w-[340px] w-full mt-6">
  
  <h3 id="hourly-title" class="text-xs font-black text-gray-700 tracking-tight mb-4 text-center">
    3-Hour Forecast
  </h3>

  <div id="hourly-range-container" class="flex flex-col w-full">
    
    {Array.from({ length: 8 }).map(() => (
      <div class="hour-item flex items-center justify-between py-2 px-3 mb-2 rounded-xl border border-gray-100/50 bg-white/40 transition-all duration-150 w-full">
        <div class="hour-time text-xs font-bold text-gray-500 w-12 flex-shrink-0">--:--</div>
                
        <div class="hour-emoji flex-1 flex items-center justify-center mx-2">
          <div class="w-7 h-7 flex items-center justify-center">
            </div>
        </div>
        
        <div class="hour-temp text-xs font-extrabold text-gray-700 w-12 text-right flex-shrink-0">--°</div>
      </div>
    ))}

  </div>
</div>