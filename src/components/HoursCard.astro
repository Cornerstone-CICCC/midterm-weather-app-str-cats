---
// src/components/HoursCard.astro
---

<div class="bg-white/90 backdrop-blur-md border border-gray-200/60 rounded-4xl p-5 shadow-sm h-full w-full mt-6 flex flex-col">
  
  <h3 id="hourly-title" class="text-xs font-black text-gray-700 tracking-tight mb-4 text-center">
    3-Hour Forecast
  </h3>

  <div id="hourly-range-container" class="flex flex-col w-full divide-y divide-gray-100 flex-1 justify-between">
    
    {Array.from({ length: 8 }).map(() => (
      <div class="hour-item flex items-center justify-between py-3 px-1 w-full">
        
        <div class="hour-time text-xs font-bold text-gray-500 w-12 shrink-0">--:--</div>
                
        <div class="hour-emoji flex-1 flex items-center justify-center mx-2">
          <div class="w-7 h-7 flex items-center justify-center">
            </div>
        </div>
        
        <div class="hour-temp text-xs font-extrabold text-gray-700 w-12 text-right shrink-0">--°</div>
      </div>
    ))}

  </div>
</div>