---
// src/components/HoursCard.astro
---

<div class="bg-white/90 backdrop-blur-md font-roboto rounded-4xl p-5 shadow-inner shadow-black/50 h-full w-full mt-6 flex flex-col">
  
  <h3 id="hourly-title" class="text-2xl font-bold text-gray-700 tracking-tight mb-4 text-center">
    3 Hour Forecast
  </h3>

  <div id="hourly-range-container" class="flex flex-col w-full divide-y divide-gray-100 flex-1 justify-between">
    
    {Array.from({ length: 8 }).map(() => (
      <div class="hour-item flex items-center justify-between py-3 px-1 w-full">
        
        <div class="hour-time text-xl w-1/3 font-medium text-gray-700 shrink-0">--:--</div>
                
        <div class="hour-emoji flex-1 w-1/3 flex items-center justify-center mx-2">
          <div class="w-200 h-200 flex items-center justify-center">
            </div>
        </div>
        
        <div class="hour-temp text-xl w-1/3 font-medium text-gray-700 text-right shrink-0">--°</div>
      </div>
    ))}

  </div>
</div>