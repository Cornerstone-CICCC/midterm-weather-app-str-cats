---

<div
  class="bg-white/90 rounded-3xl text-center px-6 py-3 shadow-[inset_0_4px_4px_0_rgba(0,0,0,0.25)] flex flex-col w-full"
>
  <div
    class="flex items-center flex-row justify-between border-b border-[#DBE2E6] py-2"
  >
    <span class="text-black text-[20px] flex flex-row gap-2.5">
      <img
        src="/src/assets/icons/humidity.svg"
        alt="Humidity"
        class="w-24px h-24px"
      /> Humidity
    </span>
    <span id="hero-humidity" class="text-black text-[20px]">-- %</span>
  </div>
  <div
    class="flex items-center flex-row justify-between border-b border-[#DBE2E6] py-2"
  >
    <span class="text-black text-[20px] flex flex-row gap-2.5">
      <img src="/src/assets/icons/wind.svg" alt="Wind" class="w-24px h-24px" /> Wind
    </span>
    <span id="hero-wind" class="text-black text-[20px]">-- km/h</span>
  </div>
  <div
    class="flex items-center flex-row justify-between border-b border-[#DBE2E6] py-2"
  >
    <span class="text-black text-[20px] flex flex-row gap-2.5">
      <img
        src="/src/assets/icons/entypo_air.svg"
        alt="Air Quality"
        class="w-24px h-24px"
      /> Air Quality
    </span>
    <span id="hero-air-quality" class="text-black text-[20px]">-- AQI</span>
  </div>

  <div class="flex items-center flex-row justify-between py-2">
    <span class="text-black text-[20px] flex flex-row gap-2.5">
      <img
        src="/src/assets/icons/mdi_uv-ray.svg"
        alt="UV Index"
        class="w-24px h-24px"
      /> UV Index
    </span>
    <span id="hero-uv" class="text-black text-[20px]">--</span>
  </div>
</div>
