---
// src/components/DayCard.astro
import type { DailyForecast } from "../types/weather";

interface Props {
  forecast: DailyForecast;
}

const { forecast } = Astro.props;
---

<div class="day-card flex md:flex-col items-center justify-between md:justify-center p-4 bg-white/90 backdrop-blur-md border border-gray-200/60 rounded-[24px] shadow-sm transition-all duration-150 w-full md:w-[110px] md:h-[160px] text-center" data-date={forecast.date}>
  
  <div class="day-name text-left md:text-center text-xs font-black text-gray-700 tracking-tight flex flex-col justify-center min-w-[50px] md:min-w-0 md:mb-2">
    <span class="block font-bold">--</span>
    <span class="block text-[10px] text-gray-400 font-normal mt-0.5">--/--</span>
  </div>
  
  <div class="weather-icon-temp flex items-center justify-center my-1 w-8 h-8 md:w-10 md:h-10">
    </div>

  <div class="temp-range flex md:flex-col items-center gap-2 md:gap-0.5 min-w-[60px] md:min-w-0 md:mt-2 text-xs">
    <span class="max-temp font-extrabold text-gray-700">--°</span>
    <span class="min-temp font-medium text-gray-400">--°</span>
  </div>

</div>