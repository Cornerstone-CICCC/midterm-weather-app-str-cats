---
// src/components/DayCard.astro
import type { DailyForecast } from "../types/weather";

interface Props {
  forecast: DailyForecast;
}

const { forecast } = Astro.props;
---

<div class="day-card flex-1 flex md:flex-col rounded-2xl items-center justify-between p-4 cursor-pointer" data-date={forecast.date}>
  
  <div class="day-name text-center text-xs font-black text-gray-700 tracking-tight mb-2">
    <span class="block font-bold">--</span>
    <span class="block text-[10px] text-gray-400 font-normal mt-0.5">--/--</span>
  </div>
  
  <div class="weather-icon-temp flex items-center justify-center my-1 w-10 h-10">
    </div>

  <div class="temp-range flex md:flex-col items-center gap-0.5 mt-2 text-xs">
    <span class="max-temp font-extrabold text-gray-700">--°</span>
    <span class="min-temp font-medium text-gray-400">--°</span>
  </div>
</div>