---
---

<div class="relative min-w-0 max-w-96">
  <span
    class="absolute left-4 top-1/2 -translate-y-1/2"
  >
    <img
      src="/assets/icon-search.svg"
      alt=""
      width="19"
      height="19"
      class="h-5 w-5 object-contain opacity-70"
    />
  </span>
  <input
    id="search-city-input"
    type="search"
    placeholder="Search city"
    class="h-12 w-full rounded-2xl border border-violet-100 bg-white pl-12 pr-4 text-sm text-violet-950 shadow-sm outline-none ring-violet-400 placeholder:text-violet-300 focus:ring-2"
  />
  <ul
    id="search-results"
    class="absolute left-0 right-0 top-full z-20 mt-1 hidden max-h-56 overflow-auto rounded-2xl border border-violet-100 bg-white py-1 text-sm shadow-lg"
    role="listbox"
  >
  </ul>
</div>
